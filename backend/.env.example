# Environment Configuration for BloodConnect

# MongoDB Configuration
MONGO_URL=mongodb://localhost:27017
# Or for MongoDB Atlas:
# MONGO_URL=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority

# Database Name
DB_NAME=bloodconnect

# FastAPI Configuration
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=True

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000

# Frontend Configuration
REACT_APP_API_URL=http://localhost:8000/api

# Notification Branding
# Visible in SMS message body as the app label.
NOTIFICATION_APP_NAME=BloodLinks

# Optional public HTTPS image URL for rich message previews.
# Example: https://your-domain.com/assets/bloodlink-logo.png
NOTIFICATION_LOGO_URL=
