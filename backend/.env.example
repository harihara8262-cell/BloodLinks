# Environment Configuration for BloodLinks backend (Supabase)

# Supabase Configuration
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_ANON_KEY=your-supabase-anon-key

# FastAPI Configuration
DEBUG=True

# CORS Configuration
# Comma-separated list of frontend origins allowed to call backend APIs
FRONTEND_ORIGINS=http://localhost:3000,http://localhost:3002,http://localhost:5173,https://your-frontend-domain.onrender.com,https://your-frontend-domain.vercel.app

# App Security
SECRET_KEY=replace-with-a-long-random-secret

